# ============================================
# Application
# ============================================
NODE_ENV=development

# ============================================
# Client (Next.js)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Server-side only: base URL used by Next.js Route Handlers to reach the
# Express backend directly (bypasses the /api rewrite proxy for streaming).
# Never exposed to the browser. Defaults to http://localhost:4000/api if unset.
BACKEND_URL=http://localhost:4000/api

# ============================================
# Server (Express)
# ============================================
PORT=4000
CLIENT_URL=http://localhost:3000

# ============================================
# Admin Panel
# ============================================
# Password to protect document upload and deletion.
ADMIN_PASSWORD=your-strong-admin-password

# ============================================
# AI Provider
# ============================================
# Set to "gemini" or "openai"
AI_PROVIDER=gemini

# Required when AI_PROVIDER=gemini
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Required when AI_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key

# Optional: override the OpenAI API base URL (e.g. for Ollama or other compatible endpoints)
# OPENAI_BASE_URL=http://localhost:11434/v1

# Optional: override the model used for generation (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional: override the model used for embeddings (default: text-embedding-3-small)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# RAG Configuration
# ============================================
# Directory where vector store and document metadata are persisted
RAG_DATA_DIR=./data

# Number of chunks to retrieve per query
RAG_TOP_K=5

# Maximum characters per text chunk
RAG_CHUNK_SIZE=1000

# Character overlap between consecutive chunks
RAG_CHUNK_OVERLAP=200

# Maximum number of documents in the knowledge base
RAG_MAX_DOCS=50
