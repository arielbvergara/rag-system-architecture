# ============================================
# Application
# ============================================
NODE_ENV=development

# ============================================
# Client (Next.js)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ============================================
# Server (Express)
# ============================================
PORT=4000
CLIENT_URL=http://localhost:3000

# ============================================
# Google Service Account
# ============================================
# Create a service account in Google Cloud Console and grant it access
# to the Calendar, Sheets, and Drive resources you want to read.
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ============================================
# Google API Scopes (pre-configured)
# ============================================
# These are set in server/src/config/google.ts
# - https://www.googleapis.com/auth/calendar.readonly
# - https://www.googleapis.com/auth/spreadsheets.readonly
# - https://www.googleapis.com/auth/drive.readonly

# ============================================
# Gmail API (OAuth2 user credentials)
# ============================================
# Used for sending transactional emails via the Gmail API.
# Unlike Calendar/Sheets, Gmail with a personal account requires OAuth2
# user credentials (not a service account).
#
# How to obtain:
# 1. Go to Google Cloud Console → APIs & Services → Credentials
# 2. Create an OAuth 2.0 Client ID (type: Web application)
# 3. Add https://developers.google.com/oauthplayground as an Authorized Redirect URI
# 4. Visit https://developers.google.com/oauthplayground
#    → Settings → Use your own OAuth credentials → enter Client ID & Secret
# 5. Authorize scope: https://www.googleapis.com/auth/gmail.send
# 6. Exchange authorization code for tokens → copy the Refresh Token
GMAIL_CLIENT_ID=your-oauth2-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-oauth2-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_SENDER_EMAIL=your@gmail.com

# ============================================
# Gemini API (Google AI)
# ============================================
# Used for the AI menu chatbot feature.
# Obtain an API key from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ============================================
# Google Maps Platform (optional)
# ============================================
# Used for the /location page: interactive map embed and live Google Places
# reviews & rating. Without these keys the map still renders via a keyless
# embed URL and reviews fall back to placeholder data.
#
# How to obtain:
# 1. Enable billing on the project (required even within the free tier)
# 2. Go to Google Cloud Console → APIs & Services → Library
# 3. Enable "Maps Embed API" and "Places API (New)"
#    (search for "Places API (New)" — do NOT enable the legacy "Places API")
# 4. Go to APIs & Services → Credentials → Create Credentials → API Key
# 5. Optionally restrict the key to those two APIs under "API restrictions"
#
# GOOGLE_MAPS_API_KEY      → add to server/.env.local  (used by the Places API fetch)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY → add to client/.env.local (used by the map iframe)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================
# Admin Panel
# ============================================
# Password to protect the /admin page. Use a strong, random value.
ADMIN_PASSWORD=your-strong-admin-password

# ============================================
# Cloudinary (Image Management)
# ============================================
# Find your Cloud Name, API Key, and API Secret in the Cloudinary dashboard:
# https://console.cloudinary.com → Home → API Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# The Cloudinary folder all project images are stored in (must match the upload preset folder)
CLOUDINARY_FOLDER=your-project-folder

# Used by the client-side Upload Widget (safe to expose).
# Same value as CLOUDINARY_CLOUD_NAME above.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# Create an unsigned upload preset in the Cloudinary dashboard:
# Settings → Upload → Upload Presets → Add Upload Preset
# Set Signing Mode to "Unsigned" and Folder to your project folder name.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset-name

# Same value as CLOUDINARY_FOLDER above (used by the Upload Widget to target the correct folder).
NEXT_PUBLIC_CLOUDINARY_FOLDER=your-project-folder

# ============================================
# Menu Scanner (Gemini Vision → Google Sheets)
# ============================================
# The Google Spreadsheet the scanned menu content is written to.
# The service account (GOOGLE_SERVICE_ACCOUNT_EMAIL) must have Editor access to this sheet.
# Defaults to the project's preconfigured spreadsheet if not set.
MENU_SCANNER_SPREADSHEET_ID=your-spreadsheet-id

# The numeric gid of the specific sheet tab to write to.
# Visible in the spreadsheet URL: ...#gid=XXXXX
# Defaults to 990327283 if not set.
MENU_SCANNER_SHEET_GID=990327283